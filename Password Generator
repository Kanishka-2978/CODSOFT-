import random
import string


def create_password(length, upper, lower, digits, symbols):
    characters = ""

    if upper:
        characters += string.ascii_uppercase

    if lower:
        characters += string.ascii_lowercase

    if digits:
        characters += string.digits

    if symbols:
        characters += "!@#$%^&*()_+-=[]{}?"

    if not characters:
        return None

    password = ""

    for _ in range(length):
        password += random.choice(characters)

    return password


